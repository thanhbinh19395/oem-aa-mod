<?xml version="1.0" encoding="UTF-8"?>
<!--AAP one time configuration xml for HU -->
<!--NOTE:
1. These tag values are specific to a platform.
2. Default values and possible options are mentioned in the comments.
3. If the application doesn't provide a tag, the respective default values will be used in the stack.
4. All the tags are case sensitive. User should preserve the existing case.
Refer the Configuration Parameters in the Appendix section of API documentation for more information. -->

<aap_attributes>
    <head_unit>
        <make>Visteon</make>
        <model>Connectivity Master Unit</model>
        <root_cert_file>/etc/androidauto/ca.pem</root_cert_file>
        <client_cert_file>/etc/androidauto/ucp/Mazda-2018-02-21-signed-CMU_2018.pem</client_cert_file>
        <private_key_file>/etc/androidauto/ucp/Mazda-2018-02-21-CMU_2018.key</private_key_file>
        <display>
            <width>800</width>
            <height>480</height>
        </display>
        <input_devices>
            <touch_screen>
                <use_internally>false</use_internally>
                <path>/dev/input/filtered-touchscreen0</path>
                <type>AAP_TOUCH_SCREEN_TYPE_CAPACITIVE</type>
                <as_secondary_input>false</as_secondary_input>
            </touch_screen>
            <key_codes>
                <value>AAP_KEYCODE_SEARCH</value>
                <value>AAP_KEYCODE_MEDIA_PLAY</value>
                <value>AAP_KEYCODE_MEDIA_PREVIOUS</value>
                <value>AAP_KEYCODE_MEDIA_NEXT</value>
                <value>AAP_KEYCODE_NAVIGATION</value>
                <value>AAP_KEYCODE_TEL</value>
                <value>AAP_KEYCODE_MEDIA</value>
                <value>AAP_KEYCODE_BACK</value>
                <value>AAP_KEYCODE_HOME</value>
                <value>AAP_KEYCODE_ROTARY_CONTROLLER</value>
                <value>AAP_KEYCODE_DPAD_UP</value>
                <value>AAP_KEYCODE_DPAD_DOWN</value>
                <value>AAP_KEYCODE_DPAD_LEFT</value>
                <value>AAP_KEYCODE_DPAD_RIGHT</value>
                <value>AAP_KEYCODE_DPAD_CENTER</value>
            </key_codes>
        </input_devices>
    </head_unit>
    <application>
        <video>
            <resolution>
                <value>800x480</value>
                <density>141</density>
                <real_density>141</real_density>
                <par>10670</par>
                <fps>60</fps>
                <decoder_additional_depth>3</decoder_additional_depth>
            </resolution>
            <codec_profile>
                <value>H.264_BP_L3.1</value>
            </codec_profile>
        </video>
        <audio>
            <stream_media>
                <type>PCM_48KHZ_2</type>
                <bps>16</bps>
                <device_id>androidautoMainAudio</device_id>
            </stream_media>
            <stream_guidance>
                <type>PCM_16KHZ_1</type>
                <bps>16</bps>
                <device_id>androidautoAltAudio</device_id>
            </stream_guidance>
            <stream_microphone>
                <type>PCM_16KHZ_1</type>
                <bps>16</bps>
                <device_id>androidautoMainAudioVR</device_id>
            </stream_microphone>
        </audio>
        <!-- List of application / activity status subscription required.  -->
        <subscription_list>
            <phone>
                <subscribe>TRUE</subscribe>
            </phone>
            <media_playback>
                <subscribe>FALSE</subscribe>
            </media_playback>
            <navigation>
                <subscribe>TRUE</subscribe>
                <cluster_type>ENUM</cluster_type>
            </navigation>
            <notification>
                <subscribe>FALSE</subscribe>
            </notification>
            <radio>
                <subscribe>FALSE</subscribe>
            </radio>
        </subscription_list>
    </application>
</aap_attributes>
<!-- End of aap attributes-->
